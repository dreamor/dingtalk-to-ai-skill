# 钉钉 + AI Provider 集成系统配置

# ============== 钉钉配置 ==============
# 钉钉应用 Key (ClientID)
DINGTALK_APP_KEY=your_dingtalk_app_key

# 钉钉应用 Secret (ClientSecret)
DINGTALK_APP_SECRET=your_dingtalk_app_secret

# ============== Gateway 配置 ==============
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
# API 访问令牌（可选，用于保护敏感接口）
GATEWAY_API_TOKEN=your_api_token_here

# ============== AI Provider 选择 ==============
# 选择使用的 AI CLI: opencode 或 claude
AI_PROVIDER=opencode

# ============== OpenCode CLI 配置 ==============
# 是否启用 OpenCode
OPENCODE_ENABLED=true

# OpenCode 命令路径（默认 opencode，如不在 PATH 中请指定完整路径）
OPENCODE_COMMAND=opencode

# OpenCode 执行超时时间 (毫秒，默认 2 分钟)
OPENCODE_TIMEOUT=120000

# 最大重试次数
OPENCODE_MAX_RETRIES=1

# OpenCode 工作目录（默认当前目录）
OPENCODE_WORKING_DIR=

# OpenCode 模型名称（留空使用 OpenCode CLI 默认配置）
OPENCODE_MODEL=

# 最大输入长度（字符数）
OPENCODE_MAX_INPUT_LENGTH=10000

# ============== Claude Code CLI 配置 ==============
# 是否启用 Claude Code
CLAUDE_ENABLED=true

# Claude Code 命令路径（默认 claude，如不在 PATH 中请指定完整路径）
CLAUDE_COMMAND=claude

# Claude Code 执行超时时间 (毫秒，默认 2 分钟)
CLAUDE_TIMEOUT=120000

# 最大重试次数
CLAUDE_MAX_RETRIES=1

# Claude Code 工作目录（默认当前目录）
CLAUDE_WORKING_DIR=

# Claude Code 模型名称（留空使用 Claude CLI 默认配置）
CLAUDE_MODEL=

# 最大输入长度（字符数）
CLAUDE_MAX_INPUT_LENGTH=10000

# ============== 会话管理配置 ==============
# 会话生存时间 (毫秒，默认 30 分钟)
SESSION_TTL=1800000

# 最大历史消息数
SESSION_MAX_HISTORY=50

# ============== 消息队列配置 ==============
# 每个用户最大并发数
MQ_MAX_CONCURRENT_PER_USER=3

# 全局最大并发数
MQ_MAX_CONCURRENT_GLOBAL=10

# 令牌桶最大令牌数（流量控制）
MQ_RATE_LIMIT_TOKENS=10

# ============== Stream 模式配置（推荐） ==============
# 是否启用 Stream 模式（无需内网穿透）
STREAM_ENABLED=true

# 最大重连次数
STREAM_MAX_RECONNECT=5

# ============== 轮询模式配置（备用） ==============
# 是否启用轮询模式
POLLING_ENABLED=true

# 轮询间隔 (毫秒)
POLLING_INTERVAL=3000

# ============== 告警通知配置 ==============
# 管理员用户 ID（用于接收告警通知，通过 Stream 连接发送，无需 webhook）
# 用户 ID 可以从钉钉消息日志中获取，格式如: $:LWCP_v1:$xxxx
ALERT_ADMIN_USER_ID=

# 告警通知 @ 用户（手机号，逗号分隔）
ALERT_MENTION_USERS=

# 告警通知 @ 所有人（true/false）
ALERT_MENTION_ALL=false