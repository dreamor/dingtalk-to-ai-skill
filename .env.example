# 钉钉配置（必填）
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
# 允许使用机器人的用户ID列表，逗号分隔；* 表示允许所有人
DINGTALK_ALLOW_FROM=*

# AI Provider 配置
# 可选值: opencode, claude
AI_PROVIDER=opencode

# OpenCode 配置
OPENCODE_COMMAND=opencode
OPENCODE_TIMEOUT=120000
OPENCODE_MAX_RETRIES=3
OPENCODE_RETRY_BASE_DELAY=1000
OPENCODE_RETRY_MAX_DELAY=10000
OPENCODE_WORKING_DIR=
OPENCODE_MODEL=
OPENCODE_MAX_INPUT_LENGTH=10000

# Claude Code 配置
CLAUDE_COMMAND=claude
CLAUDE_TIMEOUT=120000
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_BASE_DELAY=1000
CLAUDE_RETRY_MAX_DELAY=10000
CLAUDE_WORKING_DIR=
CLAUDE_MODEL=
CLAUDE_MAX_INPUT_LENGTH=10000
# Claude 权限模式：default（需确认）、plan（只读）、auto-edit（自动编辑）、dangerously-skip-permissions（全自动）
CLAUDE_PERMISSION_MODE=default

# Gateway 配置
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
GATEWAY_API_TOKEN=

# 会话配置
SESSION_TTL=1800000
# 空闲轮转阈值（分钟），超过此时间未活动的会话自动创建新会话（防上下文漂移）
SESSION_IDLE_RESET_MINS=30
SESSION_MAX_HISTORY=50
SESSION_MAX_SESSIONS=1000

# 消息队列配置
MQ_MAX_CONCURRENT_PER_USER=3
MQ_MAX_CONCURRENT_GLOBAL=10
MQ_RATE_LIMIT_TOKENS=10
MQ_POLL_INTERVAL=100
# 是否启用 SQLite 消息队列持久化（重启后消息不丢失）
MQ_ENABLE_PERSISTENCE=true

# Stream 配置
STREAM_ENABLED=true
STREAM_MAX_RECONNECT=10
STREAM_RECONNECT_BASE_DELAY=1000
STREAM_RECONNECT_MAX_DELAY=60000

# 持久化存储配置
# SQLite 数据库文件路径（默认：./data/dingtalk.db）
STORAGE_DB_PATH=./data/dingtalk.db
STORAGE_ENABLE_WAL=true
STORAGE_CLEANUP_INTERVAL=3600000

# 媒体处理配置
MEDIA_ENABLED=true
MEDIA_VOICE_TRANSCRIPTION=false
MEDIA_IMAGE_DESCRIPTION=false
MEDIA_MAX_FILE_SIZE=10485760
MEDIA_DOWNLOAD_TIMEOUT=30000

# 多 Agent 路由配置
ROUTER_ENABLED=false
# ROUTER_PROVIDERS=
# ROUTER_RULES=

# 定时任务配置
SCHEDULER_ENABLED=false
# SCHEDULER_TASKS=

# 项目记忆配置
MEMORY_ENABLED=true
MEMORY_AUTO_SUMMARIZE=true
MEMORY_SUMMARIZE_THRESHOLD=20
MEMORY_MAX_CONTEXT=10
MEMORY_AUTO_MAX_AGE=7776000000
MEMORY_BOOST_ON_ACCESS=true
MEMORY_BOOST_INCREMENT=0.1

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_ENABLE_FILE=false
LOG_FILE_PATH=

# 流式输出配置
STREAMING_ENABLED=true
STREAMING_INTERVAL_MS=1500
STREAMING_MIN_DELTA_CHARS=30
STREAMING_MAX_CHARS=2000
# AI 卡片模板 ID（钉钉卡片平台的流式卡片模板）
STREAMING_CARD_TEMPLATE_ID=82632605-8031-4963-8a92-d25e2ca8aad7.schema

# 显示过滤配置
# 显示模式：full（全部显示）、compact（紧凑，默认）、quiet（仅最终结果）
DISPLAY_MODE=compact
DISPLAY_THINKING_MESSAGES=true
DISPLAY_THINKING_MAX_LEN=300
DISPLAY_TOOL_MESSAGES=true
DISPLAY_TOOL_MAX_LEN=500

# 持久化会话配置（消除 Claude CLI 冷启动延迟）
# 启用后，同一会话复用已有 Claude CLI 进程，无需每次冷启动
PERSISTENT_SESSION_ENABLED=true
PERSISTENT_SESSION_MAX_SESSIONS=10
PERSISTENT_SESSION_IDLE_TIMEOUT=1800000
