# 钉钉配置（必填）
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret

# AI Provider 配置
# 可选值: opencode, claude
AI_PROVIDER=opencode

# OpenCode 配置
OPENCODE_COMMAND=opencode
OPENCODE_TIMEOUT=120000
OPENCODE_MAX_RETRIES=3
OPENCODE_RETRY_BASE_DELAY=1000
OPENCODE_RETRY_MAX_DELAY=10000
OPENCODE_WORKING_DIR=
OPENCODE_MODEL=
OPENCODE_MAX_INPUT_LENGTH=10000

# Claude Code 配置
CLAUDE_COMMAND=claude
CLAUDE_TIMEOUT=120000
CLAUDE_MAX_RETRIES=3
CLAUDE_RETRY_BASE_DELAY=1000
CLAUDE_RETRY_MAX_DELAY=10000
CLAUDE_WORKING_DIR=
CLAUDE_MODEL=
CLAUDE_MAX_INPUT_LENGTH=10000

# Gateway 配置
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
GATEWAY_API_TOKEN=

# 会话配置
SESSION_TTL=1800000
SESSION_MAX_HISTORY=50

# 消息队列配置
MQ_MAX_CONCURRENT_PER_USER=3
MQ_MAX_CONCURRENT_GLOBAL=10
MQ_RATE_LIMIT_TOKENS=10
MQ_POLL_INTERVAL=100
MQ_ENABLE_PERSISTENCE=false

# Stream 配置
STREAM_ENABLED=true
STREAM_MAX_RECONNECT=10
STREAM_RECONNECT_BASE_DELAY=1000
STREAM_RECONNECT_MAX_DELAY=60000

# 持久化存储配置
STORAGE_DB_PATH=
STORAGE_ENABLE_WAL=true
STORAGE_CLEANUP_INTERVAL=3600000

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_ENABLE_FILE=false
LOG_FILE_PATH=
